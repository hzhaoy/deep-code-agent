/* Deep Code Agent TUI - Main Stylesheet */

* {
    scrollbar-background: #171717;
    scrollbar-color: #555555;
    scrollbar-color-hover: #777777;
    scrollbar-color-active: #999999;
}

Screen {
    background: #171717;
    color: #e8e8e8;
}

Screen:light {
    background: #f3f3f3;
    color: #222222;
}

#codex-shell {
    height: 1fr;
    width: 100%;
    background: #171717;
}

#chat_log {
    height: 1fr;
    border: none;
    padding: 0;
    background: #171717;
}

#input_box {
    height: auto;
}

#user-input {
    width: 100%;
}

Screen:light #codex-shell,
Screen:light #chat_log {
    background: #f3f3f3;
}

Screen:light InputBox,
Screen:light StatusBar {
    background: #f3f3f3;
}

Screen:light InputBox #prompt-row {
    background: #e0e0e0;
}
